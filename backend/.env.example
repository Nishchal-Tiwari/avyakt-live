# Server
NODE_ENV=development
PORT=4000

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/yoga_class?schema=public"

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# LiveKit (self-hosted SFU - see livekit-server/ folder)
# Local dev: ws://localhost:7880 (after `cd livekit-server && docker compose up -d`)
# Production: wss://livekit.yourdomain.com
LIVEKIT_URL=ws://localhost:7880
# Must match keys in livekit-server/livekit.yaml
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
